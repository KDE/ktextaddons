include(CMakeFindDependencyMacro)

find_dependency(
    Qt6Gui
    "@QT_REQUIRED_VERSION@"
)

find_dependency(
    KF6SyntaxHighlighting
    "@KF_MIN_VERSION@"
)

find_dependency(
    KF6ColorScheme
    "@KF_MIN_VERSION@"
)

include("${CMAKE_CURRENT_LIST_DIR}/KF6TextUtilsTargets.cmake")

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:119
#, kde-format
msgid "General use models based on Llama and Llama 2 from Nous Research."
msgstr ""
"Modely na všeobecné použitie založené na Llama a Llama 2 od Nous Research."

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:120
#, kde-format
msgid "Code generation model based on Code Llama."
msgstr "Model na generovanie kódu založený na Code Llama."

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:121
#, kde-format
msgid "An extension of Llama 2 that supports a context of up to 128k tokens."
msgstr "Rozšírenie Llama 2, ktoré podporuje kontext až do 128k tokenov."

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:122
#, kde-format
msgid ""
"A 7B and 15B uncensored variant of the Dolphin model family that excels at "
"coding, based on StarCoder2."
msgstr ""
"Necenzurovaný variant rodiny modelov Dolphin so 7B a 15B parametrami, ktorý "
"vyniká v programovaní a je založený na StarCoder2."

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:123
#, kde-format
msgid "General use model based on Llama 2."
msgstr "Univerzálny model založený na Llama 2."

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:124
#, kde-format
msgid "A strong, economical, and efficient Mixture-of-Experts language model."
msgstr "Silný, ekonomický a efektívny jazykový model Mixture-of-Experts."

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:126
#, kde-format
msgid ""
"Starling is a large language model trained by reinforcement learning from AI "
"feedback focused on improving chatbot helpfulness."
msgstr ""
"Starling je veľký jazykový model trénovaný posilňovaným učením zo spätnej "

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:79
#, kde-format
msgid ""
"A family of small models with 135M, 360M, and 1.7B parameters, trained on a "
"new high-quality dataset."
msgstr ""
"Rodina malých modelov s 135M, 360M a 1,7B parametrami, trénovaná na novej "

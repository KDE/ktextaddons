#: plugins/ollamacommon/ollamacommonmodelutils.cpp:91
#, kde-format
msgid "State-of-the-art code generation model"
msgstr "Špičkový model na generovanie kódu"

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:93
#, kde-format
msgid ""
"Stable Code 3B is a coding model with instruct and code completion variants "

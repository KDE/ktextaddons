msgstr "Rodina otvorených základných modelov od IBM pre Code Intelligence"

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:78
#, kde-format
msgid ""
"Mistral OpenOrca is a 7 billion parameter model, fine-tuned on top of the "
"Mistral 7B model using the OpenOrca dataset."
msgstr ""
"Mistral OpenOrca je model so 7 miliardami parametrov, doladený na základe "

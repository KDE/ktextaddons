#: plugins/ollamacommon/ollamacommonmodelutils.cpp:127
#, kde-format
msgid ""
"A companion assistant trained in philosophy, psychology, and personal "
"relationships. Based on Mistral."
msgstr ""
"Spoločenský asistent trénovaný vo filozofii, psychológii a osobných "

msgstr ""
"Model založený na Llama 2 doladený na zlepšenie schopnosti čínskeho dialógu."

#: plugins/ollamacommon/ollamacommonmodelutils.cpp:83
#, kde-format
msgid ""
"BGE-M3 is a new model from BAAI distinguished for its versatility in Multi-"
